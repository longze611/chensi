# Database
DATABASE_URL="mysql://thinking_user:thinking_password@localhost:3306/thinking_v2"

# Optional fallback LLM configuration.
# The app also supports saving provider settings from the UI at /api/settings/ai.
# If no API key is configured, Chensi falls back to local rule-based agents.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
OPENAI_BASE_URL="https://api.openai.com/v1"

# Optional provider examples for reference. Configure these in the UI if preferred.
DEEPSEEK_API_KEY=""
ZHIPU_API_KEY=""
KIMI_API_KEY=""
GOOGLE_API_KEY=""
